        "id": "tmdb-get-images",
        "name": "TMDB Get Images",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.3,
        "position": [
          1376,
          0
        ]
      },
      {
        "parameters": {
          "jsCode": "const imagesResponse = $input.first().json;\nconst extractData = $('Extract Movie ID').first().json;\nconst originalData = extractData.originalData;\n\nconst BASE_URL = 'https://image.tmdb.org/t/p/';\nconst BACKDROP_SIZE = 'w1280';\nconst POSTER_SIZE = 'w500';\n\n// Wrap URL in Excel HYPERLINK formula for clickable links\nfunction hyperlink(url, label) {\n  if (!url) return '';\n  return '=HYPERLINK(\"' + url + '\", \"' + label + '\")';\n}\n\nif (!extractData.movieFound || !imagesResponse.backdrops) {\n  return {\n    json: {\n      ...originalData,\n      'URL 1': 'NOT FOUND',\n      'URL 2': '', 'URL 3': '', 'URL 4': '', 'URL 5': '',\n      'URL 6': '', 'URL 7': '', 'URL 8': '', 'URL 9': '', 'URL 10': ''\n    }\n  };\n}\n\nconst backdrops = imagesResponse.backdrops || [];\nconst posters = imagesResponse.posters || [];\n\nconst cleanBackdrops = backdrops.filter(img =>\n  img.iso_639_1 === null || img.iso_639_1 === 'pl'\n);\nconst cleanPosters = posters.filter(img =>\n  img.iso_639_1 === 'pl' || img.iso_639_1 === null\n);\n\nfunction scorePoster(img) {\n  let score = 0;\n  if (img.iso_639_1 === 'pl') score += 1000;\n  if (img.iso_639_1 === null) score += 500;\n  score += (img.vote_average || 0) * 10;\n  score += Math.min(img.vote_count || 0, 100);\n  return score;\n}\n\nfunction scoreBackdrop(img) {\n  let score = 0;\n  if (img.iso_639_1 === null) score += 1000;\n  if (img.iso_639_1 === 'pl') score += 500;\n  score += (img.vote_average || 0) * 10;\n  score += Math.min(img.vote_count || 0, 100);\n  return score;\n}\n\nconst scoredPosters = cleanPosters\n  .map(img => ({ ...img, score: scorePoster(img), fullUrl: `${BASE_URL}${POSTER_SIZE}${img.file_path}` }))\n  .sort((a, b) => b.score - a.score);\nconst firstPoster = scoredPosters[0]?.fullUrl || '';\n\nconst scoredBackdrops = cleanBackdrops\n  .map(img => ({ ...img, score: scoreBackdrop(img), fullUrl: `${BASE_URL}${BACKDROP_SIZE}${img.file_path}` }))\n  .sort((a, b) => b.score - a.score);\n\nconst total = scoredBackdrops.length;\nconst stride = Math.max(1, Math.floor(total / 9));\nconst selectedBackdrops = [];\nfor (let i = 0; i < 9 && i * stride < total; i++) {\n  selectedBackdrops.push(scoredBackdrops[i * stride]);\n}\n\nreturn {\n  json: {\n    ...originalData,\n    'URL 1': firstPoster ? hyperlink(firstPoster, 'Poster') : 'NOT FOUND',\n    'URL 2': selectedBackdrops[0] ? hyperlink(selectedBackdrops[0].fullUrl, 'Backdrop 1') : '',\n    'URL 3': selectedBackdrops[1] ? hyperlink(selectedBackdrops[1].fullUrl, 'Backdrop 2') : '',\n    'URL 4': selectedBackdrops[2] ? hyperlink(selectedBackdrops[2].fullUrl, 'Backdrop 3') : '',\n    'URL 5': selectedBackdrops[3] ? hyperlink(selectedBackdrops[3].fullUrl, 'Backdrop 4') : '',\n    'URL 6': selectedBackdrops[4] ? hyperlink(selectedBackdrops[4].fullUrl, 'Backdrop 5') : '',\n    'URL 7': selectedBackdrops[5] ? hyperlink(selectedBackdrops[5].fullUrl, 'Backdrop 6') : '',\n    'URL 8': selectedBackdrops[6] ? hyperlink(selectedBackdrops[6].fullUrl, 'Backdrop 7') : '',\n    'URL 9': selectedBackdrops[7] ? hyperlink(selectedBackdrops[7].fullUrl, 'Backdrop 8') : '',\n    'URL 10': selectedBackdrops[8] ? hyperlink(selectedBackdrops[8].fullUrl, 'Backdrop 9') : ''\n  }\n};"
        },
