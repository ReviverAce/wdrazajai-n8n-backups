        "id": "1b0e32c1-8395-4b36-ba4c-61af91f07640",
        "name": "TMDB Search Movie",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.3,
        "position": [
          1120,
          -48
        ]
      },
      {
        "parameters": {
          "jsCode": "const searchResults = $input.first().json;\nconst originalData = $('Loop Over Items').first().json;\n\nfunction getField(name) {\n  if (originalData[name] !== undefined) return originalData[name];\n  const key = Object.keys(originalData).find(k => k.trim() === name);\n  return key ? originalData[key] : undefined;\n}\n\nconst queryTitle = (getField('Tytuł') || '').trim().toLowerCase();\nconst inputYear = parseInt(getField('Rok produkcji'));\n\nif (!searchResults.results || searchResults.results.length === 0) {\n  return {\n    json: {\n      movieId: null,\n      movieTitle: null,\n      originalData: originalData,\n      movieFound: false\n    }\n  };\n}\n\nconst results = searchResults.results;\n\nfunction getYear(movie) {\n  if (!movie.release_date) return null;\n  return parseInt(movie.release_date.substring(0, 4));\n}\n\nfunction normalize(str) {\n  return (str || '').trim().toLowerCase();\n}\n\nlet match = results.find(m =>\n  normalize(m.title) === queryTitle && getYear(m) === inputYear\n);\n\nif (!match) {\n  match = results.find(m =>\n    normalize(m.original_title) === queryTitle && getYear(m) === inputYear\n  );\n}\n\nif (!match) {\n  match = results.find(m =>\n    normalize(m.title) === queryTitle &&\n    getYear(m) !== null && Math.abs(getYear(m) - inputYear) <= 1\n  );\n}\n\nif (!match) {\n  match = results.find(m =>\n    normalize(m.title).startsWith(queryTitle) && getYear(m) === inputYear\n  );\n}\n\nif (!match) {\n  match = results.find(m => getYear(m) === inputYear);\n}\n\nif (!match && results.length > 0) {\n  match = results[0];\n}\n\nif (!match) {\n  return {\n    json: {\n      movieId: null,\n      movieTitle: null,\n      originalData: originalData,\n      movieFound: false\n    }\n  };\n}\n\nreturn {\n  json: {\n    movieId: match.id,\n    movieTitle: match.title,\n    originalData: originalData,\n    movieFound: true\n  }\n};"
        },
