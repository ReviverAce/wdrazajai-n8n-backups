        "id": "b55bf09b-34b0-4d86-86e9-4af7c7e0687f",
        "name": "TMDB Get Images",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.3,
        "position": [
          1568,
          -48
        ]
      },
      {
        "parameters": {
          "jsCode": "const imagesResponse = $input.first().json;\nconst extractData = $('Extract Movie ID').first().json;\nconst originalData = extractData.originalData;\n\nconst BASE_URL = 'https://image.tmdb.org/t/p/';\nconst BACKDROP_SIZE = 'w1280';\nconst POSTER_SIZE = 'w500';\n\nconst result = {};\nfor (const key of Object.keys(originalData)) {\n  result[key] = originalData[key];\n}\n\nfunction findUrlKey(num) {\n  const target = 'URL ' + num;\n  const exactKey = Object.keys(originalData).find(k => k.trim() === target);\n  return exactKey || target;\n}\n\nif (!extractData.movieFound || !imagesResponse.backdrops) {\n  result.tmdbFailed = true;\n  return { json: result };\n}\n\nconst backdrops = imagesResponse.backdrops || [];\nconst posters = imagesResponse.posters || [];\n\nif (backdrops.length === 0 && posters.length === 0) {\n  result.tmdbFailed = true;\n  return { json: result };\n}\n\nfunction scorePoster(img) {\n  let score = 0;\n  if (img.iso_639_1 === 'pl') score += 2000;\n  else if (img.iso_639_1 === null) score += 1000;\n  else if (img.iso_639_1 === 'en') score += 500;\n  score += (img.vote_average || 0) * 10;\n  score += Math.min(img.vote_count || 0, 100);\n  return score;\n}\n\nconst scoredPosters = posters\n  .map(img => ({ ...img, score: scorePoster(img), fullUrl: BASE_URL + POSTER_SIZE + img.file_path }))\n  .sort((a, b) => b.score - a.score);\nconst firstPoster = scoredPosters[0] ? scoredPosters[0].fullUrl : '';\n\nfunction scoreBackdrop(img) {\n  let score = 0;\n  if (img.iso_639_1 === null) score += 2000;\n  else if (img.iso_639_1 === 'pl') score += 1000;\n  else if (img.iso_639_1 === 'en') score += 500;\n  score += (img.vote_average || 0) * 10;\n  score += Math.min(img.vote_count || 0, 100);\n  return score;\n}\n\nconst scoredBackdrops = backdrops\n  .map(img => ({ ...img, score: scoreBackdrop(img), fullUrl: BASE_URL + BACKDROP_SIZE + img.file_path }))\n  .sort((a, b) => b.score - a.score);\n\nconst seen = new Set();\nconst uniqueBackdrops = scoredBackdrops.filter(img => {\n  if (seen.has(img.file_path)) return false;\n  seen.add(img.file_path);\n  return true;\n});\n\nconst total = uniqueBackdrops.length;\nconst selectedBackdrops = [];\n\nif (total <= 9) {\n  selectedBackdrops.push(...uniqueBackdrops.slice(0, 9));\n} else {\n  const groupSize = Math.floor(total / 3);\n  const group1 = uniqueBackdrops.slice(0, groupSize);\n  const group2 = uniqueBackdrops.slice(groupSize, groupSize * 2);\n  const group3 = uniqueBackdrops.slice(groupSize * 2);\n\n  for (const group of [group1, group2, group3]) {\n    const step = Math.max(1, Math.floor(group.length / 3));\n    for (let i = 0; i < 3 && i * step < group.length; i++) {\n      selectedBackdrops.push(group[i * step]);\n    }\n  }\n}\n\nresult.tmdbFailed = false;\nresult[findUrlKey(1)] = firstPoster || 'NIE ZNALEZIONO';\nfor (let i = 0; i < 9; i++) {\n  result[findUrlKey(i + 2)] = selectedBackdrops[i] ? selectedBackdrops[i].fullUrl : '';\n}\n\nreturn { json: result };"
        },
