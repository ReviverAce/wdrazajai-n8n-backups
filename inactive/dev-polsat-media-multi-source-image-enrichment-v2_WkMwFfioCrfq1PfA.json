          "jsCode": "const serpResponse = $input.first().json;\nconst originalData = $('Loop Over Items').first().json;\n\nconst result = {};\nfor (const key of Object.keys(originalData)) {\n  result[key] = originalData[key];\n}\n\nconst images = serpResponse.images_results || [];\n\nfunction findUrlKey(num) {\n  const target = 'URL ' + num;\n  const exactKey = Object.keys(originalData).find(k => k.trim() === target);\n  return exactKey || target;\n}\n\nif (images.length === 0) {\n  result[findUrlKey(1)] = 'NIE ZNALEZIONO';\n  for (let i = 2; i <= 10; i++) result[findUrlKey(i)] = '';\n  return { json: result };\n}\n\nconst filtered = images\n  .filter(img => img.original && img.original.startsWith('http'))\n  .filter(img => {\n    if (img.original_width && img.original_width < 400) return false;\n    return true;\n  })\n  .slice(0, 10);\n\nfor (let i = 0; i < 10; i++) {\n  const key = findUrlKey(i + 1);\n  if (filtered[i]) {\n    result[key] = filtered[i].original;\n  } else {\n    result[key] = i === 0 ? 'NIE ZNALEZIONO' : '';\n  }\n}\n\nreturn { json: result };"
