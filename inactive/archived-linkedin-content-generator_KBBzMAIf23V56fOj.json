      {
        "parameters": {
          "jsCode": "const items = $input.all();\nconst sevenDaysAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000);\n\nconst articles = items.map(item => ({\n  title: item.json.title || '',\n  summary: (item.json.contentSnippet || item.json.description || item.json.content || '').substring(0, 300),\n  link: item.json.link || '',\n  pubDate: item.json.pubDate || item.json.isoDate || new Date().toISOString()\n})).filter(a => {\n  try {\n    return new Date(a.pubDate) >= sevenDaysAgo;\n  } catch { return true; }\n});\n\nconst seen = new Set();\nconst unique = articles.filter(a => {\n  const key = a.title.toLowerCase().replace(/[^a-z0-9]/g, '').substring(0, 50);\n  if (seen.has(key) || !a.title) return false;\n  seen.add(key);\n  return true;\n});\n\nunique.sort((a, b) => new Date(b.pubDate) - new Date(a.pubDate));\n\nreturn [{\n  json: {\n    articles: unique.slice(0, 15),\n    totalFound: unique.length,\n    fetchedAt: new Date().toISOString()\n  }\n}];"
        },
        "id": "deduplicate",
        "name": "4. Deduplicate & Rank Topics",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          896,
          -16
        ]
      },
      {
        "parameters": {
