          "message": "=<h2>3 New LinkedIn Post Drafts Ready!</h2><p>Your weekly LinkedIn drafts have been generated. Please review, edit, and approve them in Google Sheets.</p><h3>Quick Preview:</h3>{{ $input.all().map((item, i) => '<div style=\"border:1px solid #ddd;padding:12px;margin:8px 0;border-radius:8px;\"><strong>Post ' + (i+1) + ': ' + item.json.topic + '</strong> (' + item.json.post_format + ')<br><em>Scheduled: ' + item.json.scheduled_date + '</em><br><pre style=\"white-space:pre-wrap;font-size:13px;\">' + (item.json.post_content || '').substring(0, 300) + '...</pre></div>').join('') }}<p><strong>To approve:</strong> Open the spreadsheet and change the status column from draft to approved.</p><p><a href=\"{{ $env.LINKEDIN_SHEET_URL }}\" style=\"background:#0077B5;color:white;padding:10px 20px;text-decoration:none;border-radius:5px;\">Open Content Calendar</a></p>",
