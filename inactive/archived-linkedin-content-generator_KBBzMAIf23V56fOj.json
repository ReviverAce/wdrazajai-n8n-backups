      {
        "parameters": {
          "modelId": {
            "__rl": true,
            "mode": "id",
            "value": "gpt-4o"
          },
          "messages": {
            "values": [
              {
                "content": "=Generate 3 LinkedIn posts for this week based on these trending AI/automation topics:\n\n{{ JSON.stringify($json.trendingTopics.slice(0, 8), null, 2) }}\n\nPost formats to use: {{ $json.selectedFormats.join(', ') }}\nScheduled dates: {{ $json.scheduledDates.join(', ') }}\n\nRemember:\n- Each post should cover a DIFFERENT topic\n- Vary the tone: one educational, one opinionated, one practical\n- No links in the post body\n- 800-1800 characters per post\n- Return ONLY a JSON array with 3 objects, each having: topic, format, content, hashtags"
              }
            ]
          },
          "options": {
            "maxTokens": 4000,
            "temperature": 0.8
          }
        },
        "id": "generate_posts",
        "name": "8. Generate LinkedIn Posts",
        "type": "@n8n/n8n-nodes-langchain.openAi",
        "typeVersion": 1.8,
        "position": [
          1792,
          -112
        ]
      },
      {
        "parameters": {
          "jsCode": "const aiResponse = $input.first().json;\nconst promptData = $('6. Prepare AI Prompt').first().json;\n\nlet posts;\ntry {\n  const text = aiResponse.text || aiResponse.content || aiResponse.message || JSON.stringify(aiResponse);\n  const jsonMatch = text.match(/\\[[\\s\\S]*\\]/);\n  if (jsonMatch) {\n    posts = JSON.parse(jsonMatch[0]);\n  } else {\n    const parsed = JSON.parse(text);\n    posts = Array.isArray(parsed) ? parsed : parsed.posts || [];\n  }\n} catch (err) {\n  throw new Error('Failed to parse AI response: ' + err.message);\n}\n\nif (!Array.isArray(posts) || posts.length === 0) {\n  throw new Error('AI returned no valid posts');\n}\n\nconst now = new Date();\nconst year = promptData.year;\nconst week = promptData.weekNumber;\n\nreturn posts.slice(0, 3).map((post, index) => ({\n  json: {\n    id: 'LI-' + year + '-W' + String(week).padStart(2, '0') + '-' + (index + 1),\n    status: 'draft',\n    week_number: week,\n    scheduled_date: promptData.scheduledDates[index] || '',\n    topic: post.topic || 'AI/Automation',\n    post_format: post.format || promptData.selectedFormats[index] || 'tip',\n    post_content: post.content || '',\n    hashtags: post.hashtags || '#AI #Automation #Tech',\n    char_count: (post.content || '').length,\n    source_url: (promptData.trendingTopics[index] || {}).link || '',\n    generated_at: now.toISOString(),\n    published_at: '',\n    linkedin_post_id: '',\n    error_message: '',\n    notes: ''\n  }\n}));"
        },
