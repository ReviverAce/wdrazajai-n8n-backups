        "id": "read_previous_posts",
        "name": "5. Get Previous Posts",
        "type": "n8n-nodes-base.googleSheets",
        "typeVersion": 4.5,
        "position": [
          1120,
          -16
        ],
        "credentials": {
          "googleSheetsOAuth2Api": {
            "id": "cGJ5fju0HEKfZT5V",
            "name": "[WAI] SHEETS - MAIN"
          }
        }
      },
      {
        "parameters": {
          "jsCode": "const rssData = $('4. Deduplicate & Rank Topics').first().json;\nconst previousPosts = $('5. Get Previous Posts').all();\n\nconst fourWeeksAgo = new Date(Date.now() - 28 * 24 * 60 * 60 * 1000);\nconst recentTopics = previousPosts\n  .filter(p => {\n    try { return new Date(p.json.generated_at) >= fourWeeksAgo; }\n    catch { return false; }\n  })\n  .map(p => (p.json.topic || '').toLowerCase());\n\nconst freshArticles = rssData.articles.filter(a => {\n  const titleLower = a.title.toLowerCase();\n  return !recentTopics.some(t => t && titleLower.includes(t.substring(0, 20)));\n});\n\nconst now = new Date();\nconst startOfYear = new Date(now.getFullYear(), 0, 1);\nconst weekNumber = Math.ceil(((now - startOfYear) / 86400000 + startOfYear.getDay() + 1) / 7);\n\nconst getNextWeekday = (dayOfWeek, baseDate) => {\n  const d = new Date(baseDate);\n  d.setDate(d.getDate() + ((dayOfWeek + 7 - d.getDay()) % 7 || 7));\n  return d.toISOString().split('T')[0];\n};\n\nconst scheduledDates = [\n  getNextWeekday(2, now),\n  getNextWeekday(3, now),\n  getNextWeekday(4, now)\n];\n\nconst formats = ['tip', 'story', 'opinion', 'hot_take', 'listicle'];\nconst recentFormats = previousPosts.slice(-6).map(p => p.json.post_format || '');\nconst availableFormats = formats.filter(f => !recentFormats.slice(-2).includes(f));\nconst selectedFormats = [\n  availableFormats[0] || 'tip',\n  availableFormats[1] || 'story',\n  availableFormats[2] || 'opinion'\n];\n\nreturn [{\n  json: {\n    trendingTopics: freshArticles.slice(0, 10),\n    scheduledDates,\n    weekNumber,\n    year: now.getFullYear(),\n    selectedFormats,\n    hasTopics: freshArticles.length > 0\n  }\n}];"
        },
