      {
        "parameters": {
          "jsCode": "function sanitizeName(name) {\n  return name\n    .toLowerCase()\n    .replace(/\\[/g, \"\").replace(/\\]/g, \"\")\n    .replace(/[^a-z0-9]+/g, \"-\")\n    .replace(/^-+|-+$/g, \"\")\n    .substring(0, 80);\n}\n\nfunction getSubfolder(wf) {\n  if (wf.isArchived) return \"archived\";\n  if (wf.active) return \"active\";\n  return \"inactive\";\n}\n\nconst results = [];\nfor (const item of $input.all()) {\n  const wf = item.json;\n  const safeName = sanitizeName(wf.name);\n  const subfolder = getSubfolder(wf);\n  const filePath = subfolder + \"/\" + safeName + \"_\" + wf.id + \".json\";\n  const backupEnvelope = { _backup_meta: { backed_up_at: new Date().toISOString(), n8n_instance: \"https://wdrazajai.app.n8n.cloud\", workflow_id: wf.id, workflow_name: wf.name, active: wf.active, is_archived: wf.isArchived || false }, workflow: wf };\n  results.push({ json: { workflowId: wf.id, workflowName: wf.name, active: wf.active, isArchived: wf.isArchived || false, updatedAt: wf.updatedAt, subfolder: subfolder, filePath: filePath, fileContent: JSON.stringify(backupEnvelope, null, 2) } });\n}\nreturn results;"
        },
