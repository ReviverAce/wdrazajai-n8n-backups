        "parameters": {
          "jsCode": "const allItems = $(\"Prepare Workflow Data\").all();\nconst active = allItems.filter(i => i.json.active && !i.json.isArchived);\nconst inactive = allItems.filter(i => !i.json.active && !i.json.isArchived);\nconst archived = allItems.filter(i => i.json.isArchived);\nconst index = { last_backup: new Date().toISOString(), n8n_instance: \"https://wdrazajai.app.n8n.cloud\", total_workflows: allItems.length, by_status: { active: active.length, inactive: inactive.length, archived: archived.length }, workflows: allItems.map(i => ({ id: i.json.workflowId, name: i.json.workflowName, file: i.json.filePath, status: i.json.subfolder, updated_at: i.json.updatedAt })).sort((a, b) => a.name.localeCompare(b.name)) };\nreturn [{ json: { filePath: \"_index.json\", fileContent: JSON.stringify(index, null, 2) } }];"
