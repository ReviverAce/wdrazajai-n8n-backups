          "message": "=<h2>Post Published Successfully!</h2><p><strong>Topic:</strong> {{ $('5. Compose Post Text').first().json.topic }}</p><p><strong>Format:</strong> {{ $('5. Compose Post Text').first().json.post_format }}</p><p><strong>Characters:</strong> {{ $('5. Compose Post Text').first().json.charCount }}</p><hr><pre style=\"white-space:pre-wrap;\">{{ $('5. Compose Post Text').first().json.finalText }}</pre>",
