    "nodes": [
      {
        "id": "pub_schedule",
        "name": "Schedule Trigger",
        "type": "n8n-nodes-base.scheduleTrigger",
        "typeVersion": 1.3,
        "position": [
          0,
          0
        ],
        "parameters": {
          "rule": {
            "interval": [
              {
                "field": "cronExpression",
                "expression": "30 8 * * 2,3,4"
              }
            ]
          }
        }
      },
      {
        "id": "set_today",
        "name": "1. Get Today's Date",
        "type": "n8n-nodes-base.set",
        "typeVersion": 3.4,
        "position": [
          220,
          0
        ],
        "parameters": {
          "mode": "manual",
          "assignments": {
            "assignments": [
              {
                "id": "today",
                "name": "today",
                "value": "={{ $now.format('yyyy-MM-dd') }}",
                "type": "string"
              },
              {
                "id": "dayOfWeek",
                "name": "dayOfWeek",
                "value": "={{ $now.weekday }}",
                "type": "number"
              }
            ]
          }
        }
      },
      {
        "id": "read_approved",
        "name": "2. Read All Posts",
        "type": "n8n-nodes-base.googleSheets",
        "typeVersion": 4.7,
        "position": [
          440,
          0
        ],
        "parameters": {
          "operation": "read",
          "documentId": {
            "__rl": true,
            "mode": "url",
            "value": "={{ $env.LINKEDIN_SHEET_URL }}"
          },
          "sheetName": {
            "__rl": true,
            "mode": "name",
            "value": "Posts"
          },
          "range": "A:O",
          "options": {}
        }
      },
      {
        "id": "filter_post",
        "name": "3. Filter Today's Post",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          660,
          0
        ],
        "parameters": {
          "language": "javaScript",
          "jsCode": "const allPosts = $input.all();\nconst today = $('1. Get Today\\'s Date').first().json.today;\n\nconst approvedPosts = allPosts.filter(p => p.json.status === 'approved');\n\nlet todayPost = approvedPosts.find(p => p.json.scheduled_date === today);\n\nif (!todayPost && approvedPosts.length > 0) {\n  todayPost = approvedPosts[0];\n}\n\nif (todayPost) {\n  return [{ json: { ...todayPost.json, hasPost: true } }];\n} else {\n  return [{ json: { hasPost: false, today: today } }];\n}"
        }
      },
      {
        "id": "has_post",
        "name": "4. Has Approved Post?",
        "type": "n8n-nodes-base.if",
        "typeVersion": 2.3,
        "position": [
          880,
          0
        ],
        "parameters": {
          "conditions": {
            "options": {
              "version": 2,
              "leftValue": "",
              "caseSensitive": true,
              "typeValidation": "strict"
            },
            "combinator": "and",
            "conditions": [
              {
                "id": "has_post_cond",
                "operator": {
                  "type": "boolean",
                  "operation": "true",
                  "singleValue": true
                },
                "leftValue": "={{ $json.hasPost }}"
              }
            ]
          }
        }
      },
      {
        "id": "no_post_alert",
        "name": "No Post Alert",
        "type": "n8n-nodes-base.gmail",
        "typeVersion": 2.2,
        "position": [
          1100,
          200
        ],
        "parameters": {
          "operation": "send",
          "sendTo": "={{ $env.NOTIFICATION_EMAIL }}",
          "subject": "=LinkedIn: No approved post for today ({{ $json.today }})",
          "emailType": "html",
          "message": "=<h2>No Approved Post Available</h2><p>The LinkedIn publisher ran at 08:30 but found no approved posts for today (<strong>{{ $json.today }}</strong>).</p><p>Please approve a draft in the content calendar if you want to post today.</p><p><a href=\"{{ $env.LINKEDIN_SHEET_URL }}\">Open Content Calendar</a></p>",
          "options": {}
        }
      },
      {
        "id": "compose_post",
        "name": "5. Compose Post Text",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1100,
          -100
        ],
        "parameters": {
          "language": "javaScript",
          "jsCode": "const post = $input.first().json;\n\nlet fullText = post.post_content || '';\n\nconst hashtags = post.hashtags || '';\nif (hashtags && !fullText.includes(hashtags)) {\n  fullText = fullText.trim() + '\\n\\n' + hashtags.trim();\n}\n\nif (fullText.length > 3000) {\n  fullText = fullText.substring(0, 2997) + '...';\n}\n\nreturn [{\n  json: {\n    ...post,\n    finalText: fullText,\n    charCount: fullText.length\n  }\n}];"
        }
      },
      {
        "id": "post_linkedin",
        "name": "6. Post to LinkedIn",
        "type": "n8n-nodes-base.linkedIn",
        "typeVersion": 1,
        "position": [
          1320,
          -100
        ],
        "parameters": {
          "authentication": "communityManagement",
          "resource": "post",
          "operation": "create",
          "postAs": "person",
          "person": "",
          "text": "={{ $json.finalText }}",
          "shareMediaCategory": "NONE",
          "additionalFields": {
            "visibility": "PUBLIC"
          }
        },
        "onError": "continueRegularOutput"
      },
      {
        "id": "post_success_check",
        "name": "7. Post Succeeded?",
        "type": "n8n-nodes-base.if",
        "typeVersion": 2.3,
        "position": [
          1540,
          -100
        ],
        "parameters": {
          "conditions": {
            "options": {
              "version": 2,
              "leftValue": "",
              "caseSensitive": true,
              "typeValidation": "strict"
            },
            "combinator": "and",
            "conditions": [
              {
                "id": "no_error",
                "operator": {
                  "type": "string",
                  "operation": "notExists"
                },
                "leftValue": "={{ $json.error }}"
              }
            ]
          }
        }
      },
