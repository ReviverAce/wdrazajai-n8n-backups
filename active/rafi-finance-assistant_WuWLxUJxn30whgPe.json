      {
        "parameters": {
          "jsCode": "// AI zwraca tekst JSON w polu output (string), więc go parsujemy:\nconst raw = $json[\"output\"];\n\n// usuń ewentualne znaki nowej linii i spacje\nlet clean = raw.trim();\n\n// Spróbuj sparsować – jeśli nie działa, zwróć null\nlet data;\ntry {\n  data = JSON.parse(clean);\n} catch (e) {\n  data = {\n    kwota: null,\n    waluta: \"PLN\",\n    kategoria: null,\n    detale: \"\",\n    is_expense: false,\n    reason: \"invalid JSON\"\n  };\n}\n\n// Zwróć wynik jako pojedynczy obiekt JSON\nreturn [data];\n"
        },
