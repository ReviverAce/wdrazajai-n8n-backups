          "id": "tmdb-get-images",
          "name": "TMDB Get Images",
          "type": "n8n-nodes-base.httpRequest",
          "typeVersion": 4.3,
          "position": [
            1152,
            0
          ]
        },
        {
          "parameters": {
            "jsCode": "const imagesResponse = $input.first().json;\nconst extractData = $('Extract Movie ID').first().json;\nconst originalData = extractData.originalData;\n\nconst BASE_URL = 'https://image.tmdb.org/t/p/';\nconst BACKDROP_SIZE = 'w1280';\nconst POSTER_SIZE = 'w500';\n\n// If movie was not found or images API failed, return NOT FOUND\nif (!extractData.movieFound || !imagesResponse.backdrops) {\n  return {\n    json: {\n      ...originalData,\n      'URL_1': 'NOT FOUND',\n      'URL_2': '', 'URL_3': '', 'URL_4': '', 'URL_5': '',\n      'URL_6': '', 'URL_7': '', 'URL_8': '', 'URL_9': '', 'URL_10': ''\n    }\n  };\n}\n\nconst backdrops = imagesResponse.backdrops || [];\nconst posters = imagesResponse.posters || [];\n\n// HARD FILTER: Only Polish or text-free images (no English for Polish TV)\nconst cleanBackdrops = backdrops.filter(img =>\n  img.iso_639_1 === null || img.iso_639_1 === 'pl'\n);\nconst cleanPosters = posters.filter(img =>\n  img.iso_639_1 === 'pl' || img.iso_639_1 === null\n);\n\n// Poster scoring - prioritize Polish\nfunction scorePoster(img) {\n  let score = 0;\n  if (img.iso_639_1 === 'pl') score += 1000;\n  if (img.iso_639_1 === null) score += 500;\n  score += (img.vote_average || 0) * 10;\n  score += Math.min(img.vote_count || 0, 100);\n  return score;\n}\n\n// Backdrop scoring - prioritize no text\nfunction scoreBackdrop(img) {\n  let score = 0;\n  if (img.iso_639_1 === null) score += 1000;\n  if (img.iso_639_1 === 'pl') score += 500;\n  score += (img.vote_average || 0) * 10;\n  score += Math.min(img.vote_count || 0, 100);\n  return score;\n}\n\n// URL_1: Best Polish poster\nconst scoredPosters = cleanPosters\n  .map(img => ({ ...img, score: scorePoster(img), fullUrl: `${BASE_URL}${POSTER_SIZE}${img.file_path}` }))\n  .sort((a, b) => b.score - a.score);\nconst firstPoster = scoredPosters[0]?.fullUrl || 'NOT FOUND';\n\n// URL_2 to URL_10: Diverse backdrops using stride selection (9 picks)\nconst scoredBackdrops = cleanBackdrops\n  .map(img => ({ ...img, score: scoreBackdrop(img), fullUrl: `${BASE_URL}${BACKDROP_SIZE}${img.file_path}` }))\n  .sort((a, b) => b.score - a.score);\n\nconst total = scoredBackdrops.length;\nconst stride = Math.max(1, Math.floor(total / 9));\nconst selectedBackdrops = [];\nfor (let i = 0; i < 9 && i * stride < total; i++) {\n  selectedBackdrops.push(scoredBackdrops[i * stride]);\n}\n\nreturn {\n  json: {\n    ...originalData,\n    'URL_1': firstPoster,\n    'URL_2': selectedBackdrops[0]?.fullUrl || '',\n    'URL_3': selectedBackdrops[1]?.fullUrl || '',\n    'URL_4': selectedBackdrops[2]?.fullUrl || '',\n    'URL_5': selectedBackdrops[3]?.fullUrl || '',\n    'URL_6': selectedBackdrops[4]?.fullUrl || '',\n    'URL_7': selectedBackdrops[5]?.fullUrl || '',\n    'URL_8': selectedBackdrops[6]?.fullUrl || '',\n    'URL_9': selectedBackdrops[7]?.fullUrl || '',\n    'URL_10': selectedBackdrops[8]?.fullUrl || ''\n  }\n};"
          },
