        "id": "tmdb-search",
        "name": "TMDB Search Movie",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.3,
        "position": [
          704,
          0
        ]
      },
      {
        "parameters": {
          "jsCode": "const searchResults = $input.first().json;\nconst originalData = $('Loop Over Items').first().json;\n\nconst queryTitle = (originalData[\"Tytuły filmów\"] || '').trim().toLowerCase();\nconst inputYear = parseInt(originalData[\"Rok\"]);\n\nif (!searchResults.results || searchResults.results.length === 0) {\n  return {\n    json: {\n      movieId: null,\n      movieTitle: null,\n      originalData: originalData,\n      movieFound: false\n    }\n  };\n}\n\nconst results = searchResults.results;\n\nfunction getYear(movie) {\n  if (!movie.release_date) return null;\n  return parseInt(movie.release_date.substring(0, 4));\n}\n\n// Priority 1: Exact title + exact year\nlet match = results.find(m =>\n  m.title.trim().toLowerCase() === queryTitle && getYear(m) === inputYear\n);\n\n// Priority 2: Exact title + year +/-1\nif (!match) {\n  match = results.find(m =>\n    m.title.trim().toLowerCase() === queryTitle &&\n    getYear(m) !== null && Math.abs(getYear(m) - inputYear) <= 1\n  );\n}\n\n// Priority 3: Title starts with query + exact year\nif (!match) {\n  match = results.find(m =>\n    m.title.trim().toLowerCase().startsWith(queryTitle) && getYear(m) === inputYear\n  );\n}\n\n// Priority 4: Any result with exact year match\nif (!match) {\n  match = results.find(m => getYear(m) === inputYear);\n}\n\n// No suitable match\nif (!match) {\n  return {\n    json: {\n      movieId: null,\n      movieTitle: null,\n      originalData: originalData,\n      movieFound: false\n    }\n  };\n}\n\nreturn {\n  json: {\n    movieId: match.id,\n    movieTitle: match.title,\n    originalData: originalData,\n    movieFound: true\n  }\n};"
        },
        "id": "extract-movie-id",
        "name": "Extract Movie ID",
